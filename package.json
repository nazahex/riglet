{
  "name": "root",
  "version": "0.0.0",
  "description": "The elegant developer-experience toolkit unifying setup, linting, formatting, syncing, and automation.",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/nazahex/riglet",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nazahex/riglet.git"
  },
  "bugs": {
    "url": "https://github.com/nazahex/riglet/issues"
  },
  "author": "KazViz <kaz@kazviz.com> (https://kazviz.com)",

  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "check": "biome check && prettier --c \"**/*.{md,yml,yaml}\"",
    "format": "biome check --write && prettier --w \"**/*.{md,yml,yaml}\"",
    "test": "turbo run test --continue",
    "coverage": "turbo run test --continue -- --coverage",
    "ci": "bun run clean && bun run build && bun run check && bun run test",
    "postinstall": "lefthook install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/bun": "^1.3.1",
    "lefthook": "^2.0.2",
    "packlet": "^0.3.3",
    "prettier": "^3.6.2",
    "turbo": "^2.6.0"
  },

  "packageManager": "bun@1.3.1",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
